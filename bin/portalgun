#!/bin/bash
# portalgun — install tools and register them in scripts + web UI
set -e

# ─── Configuration (overridable via env) ────────────────────────────
PORTALGUN_ROOT="${PORTALGUN_ROOT:-/opt/portalgun}"
PORTALGUN_LIB="${PORTALGUN_LIB:-$PORTALGUN_ROOT/lib}"
PORTALGUN_REGISTRY="${PORTALGUN_REGISTRY:-/var/lib/portalgun/registry}"
PORTALGUN_LOG_DIR="${PORTALGUN_LOG_DIR:-/var/log/portalgun}"
PORTALGUN_TOOLS_BASE="${PORTALGUN_TOOLS_BASE:-/opt/tools}"
PORTALGUN_WEB_DIR="${PORTALGUN_WEB_DIR:-/opt/tools-docs}"
# Source repo dir — where the merged portalgun repo lives (with installers/ and data/).
# Auto-detect: try /home/$USER/portalgun, SUDO_USER home, /root/portalgun.
if [ -z "$PORTALGUN_REPO_DIR" ]; then
    for candidate in "/home/${SUDO_USER:-$USER}/portalgun" "$HOME/portalgun" "/root/portalgun" "/opt/portalgun"; do
        if [ -d "$candidate/installers" ] && [ -d "$candidate/data" ]; then
            PORTALGUN_REPO_DIR="$candidate"
            break
        fi
    done
    PORTALGUN_REPO_DIR="${PORTALGUN_REPO_DIR:-/home/kali/portalgun}"
fi

# Bundle search path — also check /opt/portalgun directly
export PORTALGUN_BUNDLE_SEARCH="/opt/portalgun/portalgun_bundle.json /home/kali/portalgun/portalgun_bundle.json"
if [ -z "${PORTALGUN_PROFILE_ROOT:-}" ]; then
    if [ -d "$PORTALGUN_REPO_DIR/profiles" ]; then
        PORTALGUN_PROFILE_ROOT="$PORTALGUN_REPO_DIR/profiles"
    else
        PORTALGUN_PROFILE_ROOT="$PORTALGUN_ROOT/profiles"
    fi
fi
PORTALGUN_COMPONENT_ROOT="${PORTALGUN_COMPONENT_ROOT:-$PORTALGUN_ROOT/components}"
export PORTALGUN_ROOT PORTALGUN_LIB PORTALGUN_REGISTRY PORTALGUN_LOG_DIR \
       PORTALGUN_TOOLS_BASE PORTALGUN_WEB_DIR PORTALGUN_REPO_DIR \
       PORTALGUN_PROFILE_ROOT PORTALGUN_COMPONENT_ROOT

# ─── Load common lib ─────────────────────────────────────────────────
if [ ! -f "$PORTALGUN_LIB/common.sh" ]; then
    echo "portalgun: lib not found at $PORTALGUN_LIB" >&2
    echo "Did you run install.sh?" >&2
    exit 1
fi
source "$PORTALGUN_LIB/common.sh"
source "$PORTALGUN_LIB/registry.sh"
source "$PORTALGUN_LIB/detect.sh"
[ -f "$PORTALGUN_LIB/profile.sh" ] && source "$PORTALGUN_LIB/profile.sh"

# ─── Usage ───────────────────────────────────────────────────────────
usage() {
    cat <<'EOF'
portalgun — install tools and register them in scripts + web UI

USAGE
    portalgun [--profile NAME] install apt <package>
    portalgun install github <url> [target-dir]
    portalgun install burp                     # Burp Pro JAR + Java 21 + all BApps preloaded
    portalgun install sliver                   # Sliver C2 + full armory preloaded
    portalgun install all [bundle.json]        # install everything from bundle
    portalgun import burp-license <prefs.xml>  # import your registered Burp Pro license blob
    portalgun update [burp|sliver]             # default: apt+github+pip+cargo; sub: just that one
    portalgun register                         # backfill registry from current installed state
    portalgun export [outfile]                 # dump registry → portalgun_bundle.json
    portalgun list [apt|github|all]
    portalgun status
    portalgun verify [bundle.json]             # audit bundle + active profile
    portalgun profile <list|show|create|validate|apply|current|verify>
    portalgun doctor [--fix-shadows]
    portalgun sanitize [--yes]
    portalgun help

EXAMPLES
    sudo portalgun install apt nmap
    sudo portalgun install github https://github.com/akamai/BadSuccessor /opt/tools/windows/exploit
    sudo portalgun install burp                # downloads latest Pro + every BApp
    sudo portalgun import burp-license ~/my-burp-prefs.xml
    sudo portalgun install sliver              # installs sliver, runs `armory install all`
    sudo portalgun install all                 # replay from default portalgun_bundle.json
    sudo portalgun install all /tmp/bundle.json
    portalgun export                           # writes portalgun_bundle.json
    portalgun list github
    portalgun profile list
    sudo portalgun --profile joseph profile apply
    portalgun doctor
    sudo portalgun sanitize                    # prep VM for cloning (DESTRUCTIVE)

BURP PRO NOTES
    - License is NEVER baked in. Each operator imports their own prefs.xml.
    - The activated prefs.xml lives at ~/.java/.userPrefs/burp/prefs.xml on the
      machine where Burp was registered. Copy it off, then on the new box run:
          sudo portalgun import burp-license /path/to/prefs.xml
    - 'portalgun update burp' re-downloads the latest JAR and re-applies the
      stored license so Pro stays activated across updates.

EVERY install ALSO:
    1. Records the tool in the registry (/var/lib/portalgun/registry/)
    2. Updates the web UI's tool listing (portalgun_tools.json)

ENVIRONMENT (defaults shown)
    PORTALGUN_ROOT=/opt/portalgun
    PORTALGUN_REGISTRY=/var/lib/portalgun/registry
    PORTALGUN_LOG_DIR=/var/log/portalgun
    PORTALGUN_TOOLS_BASE=/opt/tools
    PORTALGUN_WEB_DIR=/opt/tools-docs
    PORTALGUN_REPO_DIR=auto-detected (~/portalgun)
    PORTALGUN_PROFILE=default unless explicitly selected or recorded
    PORTALGUN_PROFILE_ROOT=/opt/portalgun/profiles
EOF
}

# ─── Global options + dispatch ───────────────────────────────────────
# Global options are parsed before command dispatch, so these are equivalent:
#   portalgun --profile joseph profile apply
#   portalgun profile apply joseph
while [ "$#" -gt 0 ]; do
    case "$1" in
        --profile)
            [ "$#" -ge 2 ] || { print_error "--profile requires a name"; exit 64; }
            PORTALGUN_PROFILE="$2"; export PORTALGUN_PROFILE; shift 2 ;;
        --profile=*) PORTALGUN_PROFILE="${1#*=}"; export PORTALGUN_PROFILE; shift ;;
        --target-user)
            [ "$#" -ge 2 ] || { print_error "--target-user requires a username"; exit 64; }
            PORTALGUN_TARGET_USER="$2"; export PORTALGUN_TARGET_USER; shift 2 ;;
        --target-user=*) PORTALGUN_TARGET_USER="${1#*=}"; export PORTALGUN_TARGET_USER; shift ;;
        *) break ;;
    esac
done

cmd="${1:-help}"; shift || true

case "$cmd" in
    install)
        type="${1:-}"
        case "$type" in
            apt)
                shift
                source "$PORTALGUN_LIB/install_apt.sh"
                install_apt "$@"
                ;;
            github)
                shift
                source "$PORTALGUN_LIB/install_github.sh"
                install_github "$@"
                ;;
            burp|burp-pro)
                shift
                source "$PORTALGUN_LIB/install_burp.sh"
                install_burp_pro "$@"
                ;;
            sliver)
                shift
                source "$PORTALGUN_LIB/install_sliver.sh"
                install_sliver "$@"
                ;;
            all)
                shift
                source "$PORTALGUN_LIB/apply.sh"
                apply_bundle "$@"
                ;;
            ""|-h|--help)
                usage; exit 0
                ;;
            *)
                print_error "Unknown install type: $type"
                usage
                exit 1
                ;;
        esac
        ;;
    update)
        sub="${1:-}"
        case "$sub" in
            burp|burp-pro)
                source "$PORTALGUN_LIB/install_burp.sh"
                update_burp_pro
                ;;
            sliver)
                source "$PORTALGUN_LIB/install_sliver.sh"
                update_sliver
                ;;
            *)
                source "$PORTALGUN_LIB/update.sh"
                update_all
                ;;
        esac
        ;;
    import)
        sub="${1:-}"; shift || true
        case "$sub" in
            burp-license)
                source "$PORTALGUN_LIB/install_burp.sh"
                import_burp_license "${1:-}"
                ;;
            "")
                print_error "Usage: portalgun import <burp-license> <path>"
                exit 1
                ;;
            *)
                print_error "Unknown import target: $sub"
                exit 1
                ;;
        esac
        ;;
    register)
        source "$PORTALGUN_LIB/register.sh"
        register_all
        ;;
    export)
        source "$PORTALGUN_LIB/export.sh"
        export_bundle "${1:-portalgun_bundle.json}"
        ;;
    list)
        registry_list "${1:-all}"
        ;;
    status)
        registry_status
        ;;
    verify)
        source "$PORTALGUN_LIB/verify.sh"
        verify_install "${1:-}"
        ;;
    profile)
        if ! declare -F profile_command >/dev/null 2>&1; then
            print_error "Profile engine not installed"
            exit 1
        fi
        profile_command "$@"
        ;;
    doctor)
        source "$PORTALGUN_LIB/doctor.sh" "$@"
        ;;
    sanitize)
        source "$PORTALGUN_LIB/sanitize.sh" "$@"
        ;;
    help|--help|-h|"")
        usage
        ;;
    *)
        print_error "Unknown command: $cmd"
        usage
        exit 1
        ;;
esac
