#compdef portalgun
# zsh completion for portalgun

_portalgun_profiles() {
    local root="${PORTALGUN_PROFILE_ROOT:-/opt/portalgun/profiles}"
    local -a profiles
    profiles=(${root}/*(/N:t))
    _describe -t profiles 'Portalgun profile' profiles
}

_portalgun() {
    local context state line
    typeset -A opt_args

    _arguments -C \
        '--profile[select terminal profile]:profile:_portalgun_profiles' \
        '--target-user[profile target user]:user:_users' \
        '1: :_portalgun_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $words[1] in
                install)
                    if (( CURRENT == 2 )); then
                        _values 'install type' \
                            'apt[install via apt-get]' \
                            'github[clone from GitHub, auto-detect compile]' \
                            'burp[install Burp Suite Pro]' \
                            'sliver[install Sliver C2]' \
                            'all[apply the complete bundle]'
                    elif (( CURRENT >= 3 )); then
                        case $words[2] in
                            apt) _portalgun_apt_packages ;;
                            github)
                                (( CURRENT == 3 )) && _message 'github url (https://github.com/owner/repo)'
                                (( CURRENT == 4 )) && _portalgun_tool_dirs
                                ;;
                        esac
                    fi
                    ;;
                list) _values 'type' 'all' 'apt' 'github' ;;
                update) _values 'target' 'burp' 'sliver' ;;
                profile)
                    if (( CURRENT == 2 )); then
                        _values 'profile command' list show create validate apply current verify
                    elif (( CURRENT == 3 )); then
                        case $words[2] in show|validate|apply|verify) _portalgun_profiles;; create) _message 'new profile name';; esac
                    fi
                    ;;
            esac
            ;;
    esac
}

_portalgun_commands() {
    local -a commands
    commands=(
        'install:install tools or replay the bundle'
        'update:update installed tools'
        'import:import operator-specific data such as a Burp license'
        'register:backfill the registry'
        'export:export the current bundle'
        'list:list installed tools'
        'status:show registry status'
        'verify:audit tools, services, and the active profile'
        'profile:list, create, validate, apply, or verify terminal profiles'
        'doctor:diagnose registry, symlinks, and services'
        'sanitize:prep VM for cloning (DESTRUCTIVE)'
        'help:show usage'
    )
    _describe -t commands 'portalgun command' commands
}

_portalgun_apt_packages() {
    local cache=${ZSH_CACHE_DIR:-$HOME/.cache/zsh}/portalgun-apt-pkgs
    mkdir -p "${cache:h}"
    if [[ ! -f $cache ]] || [[ $(find "$cache" -mtime +1 2>/dev/null) ]]; then
        apt-cache pkgnames 2>/dev/null > "$cache" &|
    fi
    if [[ -f $cache ]]; then
        local -a pkgs
        pkgs=(${(f)"$(<$cache)"})
        _describe -t packages 'apt package' pkgs
    else
        _message 'apt package name'
    fi
}

_portalgun_tool_dirs() {
    local base="${PORTALGUN_TOOLS_BASE:-/opt/tools}"
    local cache=${ZSH_CACHE_DIR:-$HOME/.cache/zsh}/portalgun-tooldirs
    mkdir -p "${cache:h}"
    if [[ ! -f $cache ]] || [[ $(find "$cache" -mmin +5 2>/dev/null) ]]; then
        find "$base" -maxdepth 4 -type d 2>/dev/null | sort > "$cache" &|
    fi
    if [[ -s $cache ]]; then
        local -a dirs
        dirs=(${(f)"$(<$cache)"})
        _describe -t directories 'target directory' dirs
    else
        _path_files -W "$base" -/
    fi
}

_portalgun "$@"
